rules_version = '2';

// Locked down: only someone signed in with one of your two Firebase Auth
// accounts (you + mentor) can read or write. Random visitors who find the
// URL can no longer see or touch your data.
//
// IMPORTANT ROLLOUT ORDER — read before publishing this:
//   1. Firebase Console → Authentication → Sign-in method → enable Email/Password.
//   2. Authentication → Users → Add user, twice (one for you, one for your mentor).
//   3. Deploy the updated app code (it now has a login screen).
//   4. Only then publish these rules. Publishing before steps 1-3 just means
//      the app is broken until accounts exist — it does NOT touch any of
//      your existing documents either way.
//
// Want stricter, per-person rules later (e.g. only the mentor account can
// write to `tasks`)? Replace `request.auth != null` with a check against
// the specific UID, e.g.:
//   allow write: if request.auth.uid == 'MENTOR_UID_HERE';
// You can find each account's UID in Authentication → Users after creating them.

service cloud.firestore {
  match /databases/{database}/documents {
    match /entries/{entryId} {
      allow read, write: if request.auth != null;
    }
    match /goals/{goalId} {
      allow read, write: if request.auth != null;
    }
    match /comments/{commentId} {
      allow read, write: if request.auth != null;
    }
    match /settings/{settingId} {
      allow read, write: if request.auth != null;
    }
    match /aeonArticles/{articleId} {
      allow read, write: if request.auth != null;
    }
    match /mockTests/{mockId} {
      allow read, write: if request.auth != null;
    }
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
    match /todos/{todoId} {
      allow read, write: if request.auth != null;
    }
    match /reminders/{reminderId} {
      allow read, write: if request.auth != null;
    }
  }
}
