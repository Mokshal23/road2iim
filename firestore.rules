rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is the owner of the document
    function isOwner(studentId) {
      return request.auth != null && request.auth.uid == studentId;
    }

    // Helper function to check if the user is a mentor connected to this student
    function isConnectedMentor(studentId) {
      return request.auth != null && exists(/databases/$(database)/documents/mentorships/$(request.auth.uid + '_' + studentId));
    }

    // Scoped study collections
    match /entries/{id} {
      allow read: if request.auth != null && (!('studentId' in resource.data) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId));
      allow write: if (request.auth != null && !('studentId' in resource.data)) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId);
      allow create: if isOwner(request.resource.data.studentId);
    }
    match /goals/{id} {
      allow read: if request.auth != null && (!('studentId' in resource.data) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId));
      allow write: if (request.auth != null && !('studentId' in resource.data)) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId);
      allow create: if isOwner(request.resource.data.studentId);
    }
    match /comments/{id} {
      allow read: if request.auth != null && (!('studentId' in resource.data) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId));
      allow write: if (request.auth != null && !('studentId' in resource.data)) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId);
      allow create: if isOwner(request.resource.data.studentId) || isConnectedMentor(request.resource.data.studentId);
    }
    match /aeonArticles/{id} {
      allow read: if request.auth != null && (!('studentId' in resource.data) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId));
      allow write: if (request.auth != null && !('studentId' in resource.data)) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId);
      allow create: if isOwner(request.resource.data.studentId);
    }
    match /mockTests/{id} {
      allow read: if request.auth != null && (!('studentId' in resource.data) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId));
      allow write: if (request.auth != null && !('studentId' in resource.data)) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId);
      allow create: if isOwner(request.resource.data.studentId);
    }
    match /tasks/{id} {
      allow read: if request.auth != null && (!('studentId' in resource.data) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId));
      allow write: if (request.auth != null && !('studentId' in resource.data)) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId);
      allow create: if isOwner(request.resource.data.studentId) || isConnectedMentor(request.resource.data.studentId);
    }
    match /todos/{id} {
      allow read: if request.auth != null && (!('studentId' in resource.data) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId));
      allow write: if (request.auth != null && !('studentId' in resource.data)) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId);
      allow create: if isOwner(request.resource.data.studentId);
    }
    match /reminders/{id} {
      allow read: if request.auth != null && (!('studentId' in resource.data) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId));
      allow write: if (request.auth != null && !('studentId' in resource.data)) || isOwner(resource.data.studentId) || isConnectedMentor(resource.data.studentId);
      allow create: if isOwner(request.resource.data.studentId);
    }

    // Scoped settings documents (where document ID is studentId)
    match /dailyTargets/{studentId} {
      allow read, write: if isOwner(studentId) || isConnectedMentor(studentId);
    }
    match /examDate/{studentId} {
      allow read, write: if isOwner(studentId) || isConnectedMentor(studentId);
    }

    // User profiles collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Mentorship connections
    match /mentorships/{connId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.mentorId || request.auth.uid == resource.data.studentId);
      allow write: if request.auth != null && request.auth.uid == request.resource.data.mentorId;
    }

    // Legacy settings collection for migration
    match /settings/{id} {
      allow read: if request.auth != null;
    }
  }
}
