# Copy this file to .env for local development:  cp .env.example .env
# In Vercel, add these same keys under Project Settings → Environment Variables instead.
# You'll get all six values from Firebase Console → Project settings → General → Your apps → SDK setup and configuration.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
